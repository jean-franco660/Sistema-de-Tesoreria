<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/brand_900">

    <androidx.camera.view.PreviewView
        android:id="@+id/preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Marco guía de escaneo -->
    <View
        android:layout_width="match_parent"
        android:layout_height="380dp"
        android:layout_gravity="center"
        android:layout_marginHorizontal="28dp"
        android:background="@drawable/scan_frame" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="56dp"
        android:background="@drawable/chip_soft"
        android:text="@string/encuadre"
        android:textColor="@color/brand_900"
        android:textSize="13sp"
        android:textStyle="bold" />

    <FrameLayout
        android:id="@+id/btnCerrar"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="@drawable/circle_glass"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_close"
            android:contentDescription="Cerrar" />
    </FrameLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnTomar"
        android:layout_width="match_parent"
        android:layout_height="62dp"
        android:layout_gravity="bottom"
        android:layout_margin="22dp"
        android:text="@string/tomar_foto"
        android:textSize="17sp"
        app:icon="@drawable/ic_camera"
        app:iconGravity="textStart"
        app:backgroundTint="@color/indigo_600"
        app:cornerRadius="18dp" />

    <!-- Overlay de procesamiento -->
    <LinearLayout
        android:id="@+id/overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#E60B1020"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone">

        <FrameLayout
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:background="@drawable/circle_glass">

            <ProgressBar
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:indeterminateTint="@color/white" />
        </FrameLayout>

        <TextView
            android:id="@+id/txtEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/procesando"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/powered"
            android:textColor="@color/on_dark_muted"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
